---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Productos from '../components/Productos.astro';
import WhyUs from '../components/WhyUs.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';

const whatsappNumber = '50377006710';
---
<Layout
  title="Panadería Josué | San Miguel, El Salvador"
  description="Pan fresco, repostería tradicional y pedidos especiales para eventos, directo desde nuestro horno en San Miguel."
>
  <Navbar whatsappNumber={whatsappNumber} />
  <Hero whatsappNumber={whatsappNumber} />
  <TrustBar />
  <Productos />
  <WhyUs />
  <CtaSection whatsappNumber={whatsappNumber} />
  <Footer />
</Layout>
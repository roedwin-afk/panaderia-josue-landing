---
interface Props {
  whatsappNumber: string;
}
const { whatsappNumber } = Astro.props;
const waLink = `https://wa.me/${whatsappNumber}`;
---
<div class="bg-text-main text-bg-main text-center py-2 text-xs font-semibold tracking-wide">
  ESTO ES UN EJEMPLO DEMOSTRATIVO CREADO PARA PANADERÍA JOSUÉ — NO ES SU SITIO OFICIAL ACTUAL
</div>

<header class="bg-bg-main border-b border-border py-4 sticky top-0 z-100">
  <div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
    <a href="#" class="font-heading text-2xl font-bold text-brand flex items-center gap-2">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="var(--color-brand)" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2C9.5 2 7.5 4 7 6.5C5 6.5 3 8 3 10.5C3 13 4.5 14.5 6.5 15H17.5C19.5 15 21 13 21 10.5C21 8 19 6.5 17 6.5C16.5 4 14.5 2 12 2ZM12 4C13.5 4 14.8 5.1 15 6.6L15.2 7.5H16.1C17.5 7.5 18.5 8.5 18.5 10C18.5 11.5 17.5 12.5 16.1 12.5H7.9C6.5 12.5 5.5 11.5 5.5 10C5.5 8.5 6.5 7.5 7.9 7.5H8.8L9 6.6C9.2 5.1 10.5 4 12 4ZM7 16V22H17V16H7Z"/>
      </svg>
      Panadería Josué
    </a>
    <a href="#pedidos" class="inline-flex items-center bg-accent hover:bg-accent-hover text-text-main font-bold rounded-lg px-6 py-3">
      Hacer pedido
    </a>
  </div>
</header>
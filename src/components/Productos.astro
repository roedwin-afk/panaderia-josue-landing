---
const productos = [
  {
    titulo: 'Pan Dulce y Salado',
    texto: 'El clásico de cada tarde en San Miguel. Conchas, cachitos, semitas y pan francés recién horneado con la receta de siempre.',
    icono: `<path d="M4 12c0-3.5 2.5-6 6.5-7 1-.3 2-.3 3 0 4 1 6.5 3.5 6.5 7 0 2.8-1.3 4-3 4H7c-1.7 0-3-1.2-3-4z"/><path d="M8 12v4M12 11v5M16 12v4"/>`,
  },
  {
    titulo: 'Repostería y Pasteles',
    texto: 'Detalles dulces para cada ocasión. Tartas, tres leches y nuestra especialidad en repostería fina para consentir a los tuyos.',
    icono: `<path d="M12 4c1.5 0 2.5 1.2 2.2 2.5-.2.8-.9 1.2-1.5 1.5h1.8c1.8 0 3 1.3 3.3 3H6.2c.3-1.7 1.5-3 3.3-3h1.8c-.6-.3-1.3-.7-1.5-1.5C9.5 5.2 10.5 4 12 4z"/><path d="M5.5 11h13l-1.2 8.3c-.1.9-.9 1.7-1.8 1.7H8.5c-.9 0-1.7-.8-1.8-1.7L5.5 11z"/>`,
  },
  {
    titulo: 'Pedidos Especiales',
    texto: 'Eventos, cumpleaños y ventas al por mayor. Preparamos grandes cantidades garantizando la misma calidad artesanal.',
    icono: `<rect x="4" y="9" width="16" height="11" rx="1"/><path d="M4 13h16M12 9v11"/><path d="M12 9C10 9 8.5 7.5 8.5 6S9.5 4 11 4c1 0 1 2 1 5zM12 9c2 0 3.5-1.5 3.5-3S14.5 4 13 4c-1 0-1 2-1 5z"/>`,
  },
];
---
<section id="catalogo" class="bg-bg-alt py-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12 max-w-lg mx-auto">
      <h2 class="text-brand font-heading text-4xl mb-4">Nuestro Horno</h2>
      <p class="text-text-sec">Descubre lo que preparamos a diario y lo que podemos hornear especialmente para tu próximo evento.</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {productos.map((p) => (
        <div class="bg-bg-main border border-border rounded-xl px-8 py-10 text-center hover:-translate-y-1 hover:border-brand hover:shadow-[0_12px_24px_rgba(122,46,42,0.08)] transition-all">
          <div class="w-20 h-20 mx-auto mb-6 bg-bg-alt text-brand rounded-full flex items-center justify-center">
            <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={p.icono} />
          </div>
          <h3 class="text-brand font-heading text-xl mb-3">{p.titulo}</h3>
          <p class="text-text-sec">{p.texto}</p>
        </div>
      ))}
    </div>
  </div>
</section>
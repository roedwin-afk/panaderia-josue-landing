---
import CrustDivider from './CrustDivider.astro';
---
<CrustDivider fill="var(--color-bg-alt)" />

<section class="bg-bg-alt py-8 border-b border-dashed border-border">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-8 text-center">
    <div class="flex flex-col items-center">
      <div class="bg-bg-main text-brand w-15 h-15 rounded-full flex items-center justify-center mb-4 border-2 border-border">
        <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8z"/><path d="M12 6a.996.996 0 0 0-1 1v5.586l-2.707 2.707a.999.999 0 1 0 1.414 1.414l3-3A.997.997 0 0 0 13 13V7a.996.996 0 0 0-1-1z"/></svg>
      </div>
      <h4 class="text-text-main">Años de tradición Migueleña</h4>
    </div>
    <div class="flex flex-col items-center">
      <div class="bg-bg-main text-brand w-15 h-15 rounded-full flex items-center justify-center mb-4 border-2 border-border">
        <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
      </div>
      <h4 class="text-text-main">2 Sucursales: Kury y Terminal</h4>
    </div>
    <div class="flex flex-col items-center">
      <div class="bg-bg-main text-brand w-15 h-15 rounded-full flex items-center justify-center mb-4 border-2 border-border">
        <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14h-2V9h-2V7h4v10zm4 0h-2v-4h-2v-2h2V9c0-1.1.9-2 2-2h2v2h-2v2h2v6z"/></svg>
      </div>
      <h4 class="text-text-main">Pedidos fáciles y directos</h4>
    </div>
  </div>
</section>
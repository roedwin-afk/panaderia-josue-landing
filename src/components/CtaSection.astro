---
// src/components/CtaSection.astro
import CrustDivider from './CrustDivider.astro';

interface Props {
  whatsappNumber: string;   // formato: código de país + número, sin espacios ni símbolos. Ej: "50377006710"
  whatsappMessage?: string; // mensaje precargado al abrir el chat
}

const {
  whatsappNumber,
  whatsappMessage = 'Hola, quisiera cotizar un pedido para un evento.',
} = Astro.props;

// Construimos el link wa.me a partir del número crudo + mensaje codificado
const waLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;

// Formato visible legible: +503 7700 6710
// Asumimos: 3 dígitos de código de país + resto en bloques de 4
const countryCode = whatsappNumber.slice(0, 3);
const rest = whatsappNumber.slice(3);
const formattedNumber = `+${countryCode} ${rest.slice(0, 4)} ${rest.slice(4)}`;
---

<CrustDivider fill="var(--color-text-main)" flip />

<section id="pedidos" class="bg-text-main text-bg-main py-20 pb-16 text-center">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-bg-main text-4xl font-heading mb-6">
      Haz que tu próximo evento tenga nuestro sabor.
    </h2>
    <p class="text-border text-xl mb-10 max-w-xl mx-auto">
      Escríbenos directamente indicando la fecha de tu evento, cantidad de personas y qué productos deseas encargar.
    </p>

    
    <a  href={waLink}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 bg-accent hover:bg-accent-hover text-text-main font-bold rounded-lg px-8 py-4 text-lg transition-colors"
    >
      <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
      </svg>
      Cotizar pedido por WhatsApp
    </a> 

    <div class="grid md:grid-cols-3 gap-8 mt-16 border-t border-text-sec pt-12 text-left">
      <div>
        <h4 class="text-accent font-body text-sm uppercase tracking-wide mb-2">Nuestras Sucursales</h4>
        <p class="text-bg-main text-sm leading-snug">
          <strong>Kury:</strong> Pasaje N 2, San Miguel<br />
          <strong>Terminal:</strong> 8A Avenida Norte, San Miguel
        </p>
      </div>
      <div>
        <h4 class="text-accent font-body text-sm uppercase tracking-wide mb-2">Horarios de atención</h4>
        <p class="text-bg-main text-sm leading-snug">
          Lunes a Sábado: 9:00 - 18:30<br />
          Domingo (Terminal): 10:00 - 18:30
        </p>
      </div>
      <div>
        <h4 class="text-accent font-body text-sm uppercase tracking-wide mb-2">Contacto directo</h4>
        <p class="text-bg-main text-sm leading-snug">
          Teléfono / WhatsApp:<br />
          <strong>{formattedNumber}</strong>
        </p>
      </div>
    </div>
  </div>
</section>